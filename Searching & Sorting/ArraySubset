// Problem: Array Subset
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach 1: Brute Force, Time Complexity: O(nlogn + mlogm), Space Complexity: O(1)
// Approach 2: Use hashmap to count frequency and verify if all elements of b exist in a
// Time Complexity: O(n + m)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    bool isSubset(vector<int> &a, vector<int> &b) {
        
        unordered_map<int, int> ans;
        int n1 = a.size(), n2 = b.size();
        
        // Count elements of b
        for(int i = 0; i < n2; i++){
            ans[b[i]]++;
        }
        
        // Reduce counts using a
        for(int i = 0; i < n1; i++){
            ans[a[i]]--;
        }
        
        // Check if any element still needed
        for(auto it = ans.begin(); it != ans.end(); it++){
            if(it->second > 0){
                return false;
            }
        }
        
        return true;
    }
};
