// Problem: Minimum Number of Laptops Required
// Platform: GeeksforGeeks
// Difficulty: Medium
// Approach 1: Stack way of doing the thing, Time Complexity: O(n log n), Space Complexity: O(n)
// Approach 2: Sort start and end times separately and use two-pointer technique to count overlaps
// Time Complexity: O(n log n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int minLaptops(int N, int start[], int end[]) {
        
        sort(start, start + N);
        sort(end, end + N);
        
        int i = 0, j = 0;
        int count = 0, ans = 0;
        
        while(i < N){
            
            if(start[i] < end[j]){
                count++;
                ans = max(ans, count);
                i++;
            }
            else{
                count--;
                j++;
            }
        }
        
        return ans;
    }
};
