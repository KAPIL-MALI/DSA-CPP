// Problem: Count the Zeros
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach 1: Sort the function, count the zeroes and break the loop after zeroes are counted, Time Complexity = O(n), Space Complexity = O(1).
// Approach 2: count from index 0 to n-1, Time Complexity = O(n), Space Complexity = O(1).
// Approach 3: count from index n-1 to >= 0, Time Complexity = O(n), Space Complexity = O(1).
// Approach 4: Binary Search to find the first occurrence of 0(written below)
// Time Complexity: O(log n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int countZeroes(vector<int> &arr) {
        int start = 0, end = arr.size() - 1, n = arr.size();
        int currans = 0;

        while(start <= end){
            
            int mid = start + (end - start) / 2;
            
            if(arr[mid] > 0){
                start = mid + 1;
            }
            else if(arr[mid] == 0){
                currans = mid;
                end = mid - 1;
            }
        }
        
        return n - currans;
    }
};
