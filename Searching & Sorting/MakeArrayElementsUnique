// Problem: Make Array Elements Unique
// Platform: GeeksforGeeks
// Difficulty: Medium
// Approach:
// 1. Sort the array.
// 2. Traverse the array from left to right.
// 3. If current element is not greater than previous,
//    increment it to (previous + 1).
// 4. Count total increment operations.
// Time Complexity: O(n log n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int minIncrements(vector<int>& arr) {
        
        int n = arr.size(), count = 0;
        
        sort(arr.begin(), arr.end());
        
        for(int i = 1; i < n; i++){
            
            if(arr[i - 1] == arr[i]){
                arr[i] = arr[i] + 1;
                count++;
            }
            else if(arr[i - 1] > arr[i]){
                
                int temp = arr[i];
                
                arr[i] = arr[i - 1] + 1;
                
                count += arr[i] - temp;
            }
        }
        
        return count;
    }
};
