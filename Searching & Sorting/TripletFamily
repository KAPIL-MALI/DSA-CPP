// Problem: Triplet Family
// Platform: GeeksforGeeks
// Difficulty: Basic
// Approach 1: Three for loops till n, Time Complexity = O(n^3), Space Complexity = O(1).
// Approach 2: Sort the array and use two-pointer technique to check if
// arr[left] + arr[right] == arr[i]
// Time Complexity: O(n^2)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    bool findTriplet(vector<int>& arr) {
        
        int n = arr.size();
        sort(arr.begin(), arr.end());
        
        for(int i = n - 1; i >= 2; i--){
            
            int left = 0;
            int right = i - 1;
            
            while(left < right){
                
                int sum = arr[left] + arr[right];
                
                if(sum == arr[i])
                    return true;
                
                else if(sum < arr[i])
                    left++;
                
                else
                    right--;
            }
        }
        
        return false;
    }
};
