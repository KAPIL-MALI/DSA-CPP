// Problem: First and Last Occurrence of an Element in a Sorted Array
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach 1: Brute Force => using first and last elements and count, Time Complexity = O(n), Complexity = O(1).
// Approach2 : Binary Search twice to find first and last occurrence.
// Time Complexity: O(log n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    vector<int> firstAndLast(int x, vector<int> &arr) {
        int n = arr.size();
        int low = 0, high = n-1;
        int first = -1, last = -1;
        vector<int> ans;
        
        // find first occurrence
        while(low <= high){
            
            int mid = low + (high-low)/2;
            
            if(arr[mid] > x){
                high = mid-1;
            }
            else if(arr[mid] < x){
                low = mid+1;
            }
            else{
                first = mid;
                high = mid-1;
            }
        }
        
        low = 0; 
        high = n-1;
        
        // find last occurrence
        while(low <= high){
            
            int mid = low + (high-low)/2;
            
            if(arr[mid] < x){
                low = mid+1;
            }
            else if(arr[mid] > x){
                high = mid-1;
            }
            else{
                last = mid;
                low = mid+1;
            }
        }
        
        if(first == -1){
            ans.push_back(-1);
            return ans;
        }
        
        ans.push_back(first);
        ans.push_back(last);
        
        return ans;
    }
};
