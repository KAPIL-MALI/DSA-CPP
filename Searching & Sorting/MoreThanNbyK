// Problem: More than n/k Occurrences
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach 1: Brute Force, Time Complexity = O(n^2), Space Complexity = O(1),
// Approach 2: Better Approach, sort one , Time Complexity = O(nlogn), Space Complexity = O(1),
// Approach 3: Use hashmap to count frequency of each element and check if it exceeds n/k
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int countOccurence(vector<int>& arr, int k) {
        
        int n = arr.size(), count = 0;
        int num = n / k;
        
        unordered_map<int, int> ans;
        
        // Count frequency
        for(int i = 0; i < n; i++){
            ans[arr[i]]++;
        }
        
        // Check condition
        for(auto it = ans.begin(); it != ans.end(); it++){
            if(it->second > num){
                count++;
            }
        }
        
        return count;
    }
};
