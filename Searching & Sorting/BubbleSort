// Problem: Bubble Sort
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Repeatedly swap adjacent elements if they are in the wrong order.
// Time Complexity: O(n^2)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    void bubbleSort(vector<int>& arr) {
        int n = arr.size();
        
        for(int i = 0; i < n - 1; i++){
            for(int j = 0; j < n - i - 1; j++){
                if(arr[j] > arr[j + 1]){
                    swap(arr[j], arr[j + 1]);
                }
            }
        }
    }
};
