// Problem: First Repeating Element
// Platform: InterviewBit
// Difficulty: Easy
// Approach 1: Brute Force, Time Complexity: O(n^2),Space Complexity: O(1)
// Approach 2: Use HashMap to count frequency, then traverse again to find first element with frequency > 1
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int solve(vector<int> &A) {
        
        unordered_map<int,int> m;
        int n = A.size();
        
        for(int i = 0; i < n; i++){
            m[A[i]]++;
        }
        
        for(int i = 0; i < n; i++){
            if(m[A[i]] > 1){
                return A[i];
            }
        }
        
        return -1;
    }
};
