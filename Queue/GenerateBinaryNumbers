// Problem: Generate Binary Numbers
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Use Queue (BFS) to generate binary numbers in order
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    vector<string> generateBinary(int n) {
        vector<string> ans;
        queue<string> q;
        
        q.push("1");
        
        for(int i = 0; i < n; i++) {
            string curr = q.front();
            q.pop();
            
            ans.push_back(curr);
            
            q.push(curr + "0");
            q.push(curr + "1");
        }
        
        return ans;
    }
};
