// Problem: Queue Push & Pop
// Platform: GeeksforGeeks
// Difficulty: Basic
// Approach: Use queue STL to enqueue all elements, then dequeue while printing
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    queue<int> fillQ(const vector<int>& arr) {
        queue<int> q;
        
        for(int i = 0; i < arr.size(); i++){
            q.push(arr[i]);
        }
        
        return q;
    }

    void emptyQ(queue<int>& q) {
        while(!q.empty()) {
            cout << q.front() << " ";
            q.pop();
        }
        cout << endl;
    }
};
