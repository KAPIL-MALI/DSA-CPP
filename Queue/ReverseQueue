// Problem: Queue Reversal
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Use stack to reverse the order of elements in the queue
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    void reverseQueue(queue<int> &q) {
        
        int n = q.size();
        stack<int> st;
        
        // Move elements from queue to stack
        for(int i = 0; i < n; i++){
            st.push(q.front());
            q.pop();
        }
        
        // Move elements back to queue (reversed)
        while(!st.empty()){
            q.push(st.top());
            st.pop();
        }
    }
};
