// Problem: Make the Array Beautiful
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Use stack to remove adjacent elements having different signs
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    vector<int> makeBeautiful(vector<int> arr) {
        
        stack<int> st;
        int n = arr.size();
        
        for(int i = 0; i < n; i++){
            
            if((st.size() == 0) || 
               (arr[i] >= 0 && st.top() >= 0) || 
               (arr[i] < 0 && st.top() < 0)){
                
                st.push(arr[i]);
            }
            else{
                st.pop();
            }
        }
        
        vector<int> k;
        
        while(!st.empty()){
            k.push_back(st.top());
            st.pop();
        }
        
        reverse(k.begin(), k.end());
        return k;
    }
};
