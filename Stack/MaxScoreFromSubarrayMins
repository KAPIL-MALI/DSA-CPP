// Problem: Max Score from Subarray Mins
// Platform: GeeksforGeeks
// Difficulty: Medium
// Approach 1: Brute Force, // Time Complexity: O(n^3), Space Complexity: O(1)
// Approach 2: The maximum score comes from the maximum sum of any two adjacent elements
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int maxSum(vector<int> &arr) {
        int n = arr.size();
        int maxi = 0;
        
        for(int i = 0; i < n - 1; i++)
        {
            maxi = max(maxi, arr[i] + arr[i + 1]);
        }
        
        return maxi;
    }
};
