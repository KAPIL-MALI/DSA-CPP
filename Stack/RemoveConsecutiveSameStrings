// Problem: String Manipulation (Remove Consecutive Same Strings)
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Use stack to remove adjacent equal strings by pairwise cancellation
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int removeConsecutiveSame(vector<string>& arr) {
        
        int n = arr.size();
        stack<string> st;
        
        for(int i = 0; i < n; i++){
            
            if(st.empty()){
                st.push(arr[i]);
            }
            else if(arr[i] != st.top()){
                st.push(arr[i]);
            }
            else{
                st.pop();
            }
        }
        
        return st.size();
    }
};
