// Problem: Max Equal Sum of 3 Stacks
// Platform: GeeksforGeeks
// Difficulty: Medium
// Approach: Calculate total sums and remove elements from the stack with maximum sum
// Time Complexity: O(N1 + N2 + N3)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int maxEqualSum(int N1, int N2, int N3, vector<int> &S1, vector<int> &S2,
                    vector<int> &S3) {

        int sum1 = 0, sum2 = 0, sum3 = 0;

        // calculate sums
        for(int i = 0; i < N1; i++) sum1 += S1[i];
        for(int i = 0; i < N2; i++) sum2 += S2[i];
        for(int i = 0; i < N3; i++) sum3 += S3[i];

        int i = 0, j = 0, k = 0;

        while(i < N1 && j < N2 && k < N3){

            // if all equal
            if(sum1 == sum2 && sum2 == sum3){
                return sum1;
            }

            // remove from largest sum stack
            if(sum1 >= sum2 && sum1 >= sum3){
                sum1 -= S1[i];
                i++;
            }
            else if(sum2 >= sum1 && sum2 >= sum3){
                sum2 -= S2[j];
                j++;
            }
            else{
                sum3 -= S3[k];
                k++;
            }
        }

        return 0;
    }
};
