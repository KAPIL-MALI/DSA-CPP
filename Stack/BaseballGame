// Problem: Baseball Game (682)
// Platform: LeetCode
// Difficulty: Easy
// Approach 1: This question can also be done using the array, Time Complexity: O(n), Space Complexity: O(n).
// Approach 2: Use stack to simulate score recording and apply operations
// Time Complexity: O(n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int calPoints(vector<string>& arr) {
        
        int n = arr.size();
        stack<int> st;
        
        for(int i = 0; i < n; i++)
        {
            if(arr[i] == "C")
            {
                st.pop();
            }
            else if(arr[i] == "D")
            {
                st.push(st.top() * 2);
            }
            else if(arr[i] == "+")
            {
                int first = st.top();
                st.pop();
                
                int second = st.top();
                
                st.push(first); // restore
                
                st.push(first + second);
            }
            else
            {
                st.push(stoi(arr[i]));
            }
        }
        
        int sum = 0;
        
        while(!st.empty())
        {
            sum += st.top();
            st.pop();
        }
        
        return sum;
    }
};
