// Problem: Min Number of Flips
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach:
// Check both possible alternating patterns:
// 1. 010101...
// 2. 101010...
// Count mismatches for both patterns and return the minimum.
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int minFlips(string& s) {
        
        int n = s.size();
        
        int count0 = 0, count1 = 0;

        for(int i = 0; i < n; i++){
            
            // Pattern: 010101...
            if(i % 2 == 0){
                if(s[i] != '0'){
                    count0++;
                }
            }
            else{
                if(s[i] != '1'){
                    count0++;
                }
            }

            // Pattern: 101010...
            if(i % 2 == 0){
                if(s[i] != '1'){
                    count1++;
                }
            }
            else{
                if(s[i] != '0'){
                    count1++;
                }
            }
        }

        return min(count0, count1);
    }
};
