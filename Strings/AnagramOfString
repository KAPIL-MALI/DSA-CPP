// Problem: Anagram of String
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Count frequency difference using a single array and sum absolute differences
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int remAnagram(string &str1, string &str2) {
        
        vector<int> ans(26, 0);
        int n1 = str1.size(), n2 = str2.size();
        
        if(n1 > n2){
            for(int i = 0; i < n1; i++)
                ans[str1[i] - 'a']++;
        }
        else{
            for(int i = 0; i < n2; i++)
                ans[str2[i] - 'a']++;
        }
        
        if(n1 > n2){
            for(int i = 0; i < n2; i++)
                ans[str2[i] - 'a']--;
        }
        else{
            for(int i = 0; i < n1; i++)
                ans[str1[i] - 'a']--;
        }
        
        int count = 0;
        for(int i = 0; i < ans.size(); i++){
            if(ans[i] != 0)
                count += abs(ans[i]);
        }
        
        return count;
    }
};
