// Problem: Count Primes
// Platform: LeetCode
// Approach 1: Brute Force ,Time Complexity = O(n^2), Space Complexity = O(1)
// Approach 2: Sieve of Eratosthenes to mark non-prime numbers
// Time Complexity: O(n log log n)
// Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int countPrimes(int n) {

        if(n <= 2) return 0;

        vector<bool> prime(n, true);

        prime[0] = prime[1] = false;

        for(int i = 2; i * i < n; i++){
            if(prime[i]){
                for(int j = i * i; j < n; j += i){
                    prime[j] = false;
                }
            }
        }

        int count = 0;

        for(int i = 2; i < n; i++){
            if(prime[i]) count++;
        }

        return count;
    }
};
