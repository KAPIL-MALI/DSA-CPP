// Problem: Boolean Matrix
// Platform: GeeksforGeeks
// Approach1: using stack
// Approach2: Use first row and first column as markers to track which rows and columns should be set to 1 (written below)
// Time Complexity: O(n * m)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    void booleanMatrix(vector<vector<int>>& mat) {
        int n = mat.size();
        int m = mat[0].size();

        bool firstRowHasOne = false;
        bool firstColHasOne = false;

        // 1. Check if the first row needs to be all 1s later
        for (int j = 0; j < m; j++) {
            if (mat[0][j] == 1) firstRowHasOne = true;
        }

        // 2. Check if the first column needs to be all 1s later
        for (int i = 0; i < n; i++) {
            if (mat[i][0] == 1) firstColHasOne = true;
        }

        // 3. Use first row and column as markers
        for (int i = 1; i < n; i++) {
            for (int j = 1; j < m; j++) {
                if (mat[i][j] == 1) {
                    mat[i][0] = 1;
                    mat[0][j] = 1;
                }
            }
        }

        // 4. Update internal matrix using markers
        for (int i = 1; i < n; i++) {
            for (int j = 1; j < m; j++) {
                if (mat[i][0] == 1 || mat[0][j] == 1) {
                    mat[i][j] = 1;
                }
            }
        }

        // 5. Update first row
        if (firstRowHasOne) {
            for (int j = 0; j < m; j++) mat[0][j] = 1;
        }

        // 6. Update first column
        if (firstColHasOne) {
            for (int i = 0; i < n; i++) mat[i][0] = 1;
        }
    }
};
