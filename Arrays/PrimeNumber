// Problem: Prime Number
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Handle small cases separately, then check divisibility up to sqrt(n)
// Time Complexity: O(sqrt(n))
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    bool isPrime(int n) {
        if(n == 1) return false;
        if(n == 2) return true;
        if(n % 2 == 0) return false;
        
        for(int i = 3; i * i <= n; i++){
            if(n % i == 0)
                return false;
        }
        
        return true;
    }
};
