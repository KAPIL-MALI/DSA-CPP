// Problem: Reverse String
// Platform: GeeksforGeeks
// Approach 1: reverse stl function ,Time Complexity = O(n), Space Complexity = O(1);
// Approach 2: Two-pointer technique (swap characters from start and end)
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    string reverseString(string& s) {
        int start = 0, end = s.size() - 1;

        while(start < end){
            swap(s[start], s[end]);
            start++, end--;
        }

        return s;
    }
};
