// Problem: Majority Element
// Platform: GeeksforGeeks
// Difficulty: Medium
// Approach 1: Brute Force (n^2)
// Approach 2: unordered map
// Approach 3: Boyer-Moore Majority Voting Algorithm
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int majorityElement(vector<int>& arr) {
        
        int candidate = -1;
        int count = 0;
        int n = arr.size();

        // Step 1: Find candidate
        for(int i = 0; i < n; i++){
            if(count == 0){
                candidate = arr[i];
                count = 1;
            }
            else if(arr[i] == candidate){
                count++;
            }
            else{
                count--;
            }
        }

        // Step 2: Verify candidate
        count = 0;
        for(int i = 0; i < n; i++){
            if(arr[i] == candidate){
                count++;
            }
        }

        if(count > n/2)
            return candidate;

        return -1;
    }
};
