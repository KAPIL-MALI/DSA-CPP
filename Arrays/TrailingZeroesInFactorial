// Problem: Trailing Zeroes in Factorial
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Count factors of 5 in n! by repeatedly dividing n by 5
// Time Complexity: O(log n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int trailingZeroes(int n) {
        int ans = 0;

        while(n){
            n = n / 5;
            ans += n;
        }

        return ans;
    }
};
