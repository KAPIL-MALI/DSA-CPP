// Problem: N/3 Repeat Number
// Platform: InterviewBit
// Difficulty: Medium
// Approach 1: Boyer-Moore Voting Algorithm (extended version for n/3 case).
//           At most 2 elements can appear more than n/3 times.
//           Step 1: Find potential candidates.
//           Step 2: Verify their counts.
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

int repeatedNumber(const vector<int> &A) {
    int n = A.size();
    
    int ele1 = 0, ele2 = 0;
    int count1 = 0, count2 = 0;
    
    // Step 1: Find candidates
    for(int i = 0; i < n; i++){
        int x = A[i];
        
        if(x == ele1) count1++;
        else if(x == ele2) count2++;
        else if(count1 == 0){
            ele1 = x;
            count1 = 1;
        }
        else if(count2 == 0){
            ele2 = x;
            count2 = 1;
        }
        else{
            count1--;
            count2--;
        }
    }
    
    // Step 2: Verify
    count1 = 0;
    count2 = 0;
    
    for(int i = 0; i < n; i++){
        if(A[i] == ele1) count1++;
        else if(A[i] == ele2) count2++;
    }
    
    if(count1 > n/3) return ele1;
    if(count2 > n/3) return ele2;
    
    return -1;
}
