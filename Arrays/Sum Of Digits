// Problem: Sum of Digits
// Platform: GeeksforGeeks
// Approach: Extract each digit using modulus and division
// Time Complexity: O(d)  (where d = number of digits)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int sumOfDigits(int n) {
        int ans = 0;
        while(n){
            ans += n%10;
            n /= 10;
        }
        return ans;
    }
};
