// Problem: Boolean Matrix
// Platform: GeeksforGeeks
// Approach1: stack way of doing things
// Approach2: Use first row and column as markers (Space Optimized)

class Solution {
  public:
    void booleanMatrix(vector<vector<int>>& mat) {
        int n = mat.size();
        int m = mat[0].size();

        bool firstRowHasOne = false;
        bool firstColHasOne = false;

        // Check first row
        for(int j = 0; j < m; j++){
            if(mat[0][j] == 1)
                firstRowHasOne = true;
        }

        // Check first column
        for(int i = 0; i < n; i++){
            if(mat[i][0] == 1)
                firstColHasOne = true;
        }

        // Mark rows and columns
        for(int i = 1; i < n; i++){
            for(int j = 1; j < m; j++){
                if(mat[i][j] == 1){
                    mat[i][0] = 1;
                    mat[0][j] = 1;
                }
            }
        }

        // Update matrix using markers
        for(int i = 1; i < n; i++){
            for(int j = 1; j < m; j++){
                if(mat[i][0] == 1 || mat[0][j] == 1)
                    mat[i][j] = 1;
            }
        }

        // Update first row
        if(firstRowHasOne){
            for(int j = 0; j < m; j++)
                mat[0][j] = 1;
        }

        // Update first column
        if(firstColHasOne){
            for(int i = 0; i < n; i++)
                mat[i][0] = 1;
        }
    }
};
