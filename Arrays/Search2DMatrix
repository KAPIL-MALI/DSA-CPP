// Problem: Search a 2D Matrix
// Platform: LeetCode & GFG
// Approach1 : search in row wise and then column wise , Time Complexity = O(n+m), Space Complexity = O(1)
// Approach2 : Binary Search
// Step 1: Use binary search to locate the possible row.
// Step 2: Perform binary search inside that row to find the target.
// Time Complexity: O(log m + log n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    bool searchMatrix(vector<vector<int>>& matrix, int target) {

        int m = matrix.size();
        int n = matrix[0].size();

        int rowStart = 0, rowEnd = m - 1;
        int row = -1;

        // First binary search → find the correct row
        while(rowStart <= rowEnd){

            int rowMid = rowStart + (rowEnd - rowStart)/2;

            if(target > matrix[rowMid][n-1])
                rowStart = rowMid + 1;

            else if(target < matrix[rowMid][0])
                rowEnd = rowMid - 1;

            else{
                row = rowMid;
                break;
            }
        }

        if(row == -1)
            return false;

        int colStart = 0, colEnd = n - 1;

        // Second binary search → search inside that row
        while(colStart <= colEnd){

            int colMid = colStart + (colEnd - colStart)/2;

            if(matrix[row][colMid] == target)
                return true;

            if(matrix[row][colMid] < target)
                colStart = colMid + 1;
            else
                colEnd = colMid - 1;
        }

        return false;
    }
};
