// Problem: Rotate by 90 Degree (Anti-Clockwise)
// Platform: GeeksforGeeks
// Difficulty: Medium
// Approach1: Brute Force -> Temporary Matrix, Problem -> Space qualityO(n)
// Approach2: First transpose the matrix, then reverse each column.
// Transposing swaps rows and columns. Reversing each column results
// in a 90° anti-clockwise rotation of the matrix.
// Time Complexity: O(n^2)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    void rotateMatrix(vector<vector<int>>& mat) {
        
        int row = mat.size();
        int col = mat[0].size();
        
        // Step 1: Transpose the matrix
        for(int i = 0; i < row; i++){
            for(int j = i + 1; j < col; j++){
                swap(mat[i][j], mat[j][i]);
            }
        }
        
        // Step 2: Reverse each column
        for(int j = 0; j < col; j++){
            int top = 0;
            int bottom = row - 1;
            
            while(top < bottom){
                swap(mat[top][j], mat[bottom][j]);
                top++;
                bottom--;
            }
        }
    }
};
