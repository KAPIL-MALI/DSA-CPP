// Problem: Missing in Array
// Platform: GeeksforGeeks
// Difficulty: Easy
// Approach: Sort the array and compare expected numbers sequentially
// Time Complexity: O(n log n)   (due to sorting)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

class Solution {
  public:
    int missingNum(vector<int>& arr) {
        
        int n = arr.size(), k = 1;
        sort(arr.begin(), arr.end());

        for(int i = 0; i < n; i++){
            if(arr[i] == k)
                k++;
            else
                return k;
        }

        return k;
    }
};
